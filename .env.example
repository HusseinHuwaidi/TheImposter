# Create a copy of this file and rename it to .env
# Do not commit your actual .env file to version control

# 1. Your Supabase Keys
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 2. Your Production URL or Local IP
# If you are testing locally with mobile devices on the same WiFi, put your Local IPv4 address here (e.g. http://192.168.1.5:5173)
# If you are deploying to production, put your custom domain here:
# VITE_PUBLIC_URL=https://www.theimposter.online
VITE_PUBLIC_URL=http://localhost:5173
